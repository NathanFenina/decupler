# Copie ce fichier en .env et remplis les valeurs. .env n'est JAMAIS commité.

# --- WordPress (API REST, mot de passe d'application) ---
WP_SITE_URL=https://www.decupler.com
WP_USER=ton-utilisateur
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- Google Search Console (service account) ---
GSC_SITE_URL=https://www.decupler.com/
GSC_CREDENTIALS_JSON=./secrets/gsc-service-account.json

# --- DataForSEO (si script ; sinon branché en MCP) ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Génération d'images ---
IMAGE_API_KEY=
